{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawford.dev/schemas/credential.schema.json",
  "title": "Clawford Credential",
  "description": "Schema for credentials, certificates, and badges awarded to learners. Supports the three-tier credential model: Foundation Certificate, Academy Badge, and Specialist Transcript.",
  "type": "object",
  "required": ["credentialId", "learnerId", "type", "courseId", "issuedAt", "status"],
  "properties": {
    "credentialId": {
      "type": "string",
      "description": "Unique identifier for this credential."
    },
    "learnerId": {
      "type": "string",
      "description": "Identifier of the learner who earned this credential."
    },
    "type": {
      "type": "string",
      "enum": ["foundation-certificate", "academy-badge", "specialist-transcript"],
      "description": "Credential tier."
    },
    "courseId": {
      "type": "string",
      "description": "Course that this credential was earned from."
    },
    "academyId": {
      "type": "string",
      "description": "Academy this credential belongs to (for academy badges and specialist transcripts)."
    },
    "title": {
      "type": "string",
      "description": "Human-readable credential title."
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Optional expiration date."
    },
    "status": {
      "type": "string",
      "enum": ["active", "expired", "revoked"],
      "description": "Current status of this credential."
    },
    "assessmentResults": {
      "type": "array",
      "items": { "$ref": "#/$defs/AssessmentResult" },
      "description": "Assessment outcomes that led to this credential."
    },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/$defs/ModuleCompletion" },
      "description": "Modules completed as part of earning this credential."
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvidenceItem" },
      "description": "Key evidence artifacts backing this credential."
    },
    "issuer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["first-party", "academy"]
        }
      }
    }
  },
  "$defs": {
    "AssessmentResult": {
      "type": "object",
      "required": ["assessmentId", "score", "maxScore", "decision"],
      "properties": {
        "assessmentId": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "decision": {
          "type": "string",
          "enum": ["pass", "revisit", "fail"]
        },
        "attempt": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ModuleCompletion": {
      "type": "object",
      "required": ["moduleId", "completedAt"],
      "properties": {
        "moduleId": { "type": "string" },
        "moduleCode": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "credits": { "type": "integer" }
      }
    },
    "EvidenceItem": {
      "type": "object",
      "required": ["type", "reference"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["test", "log", "diff", "trace", "user-feedback", "screenshot", "benchmark", "other"]
        },
        "reference": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}